{
  "name": "h80h-homepage",
  "version": "1.0.0",
  "description": "Personal homepage and Obsidian-powered blog",
  "scripts": {
    "start": "npx @11ty/eleventy --serve",
    "build": "git log --oneline -- blog-source/hedi-s-coding/post-2.md && npx @11ty/eleventy && npx pagefind --site blog",
    "debug": "DEBUG=Eleventy* npx @11ty/eleventy",
    "dev": "npm run build && node server.js"
  },
  "author": "h80h",
  "license": "MIT",
  "devDependencies": {
    "@11ty/eleventy": "^2.0.1",
    "@11ty/eleventy-plugin-rss": "^1.2.0",
    "markdown-it": "^13.0.1",
    "markdown-it-obsidian": "latest",
    "serve": "^14.2.6"
  },
  "dependencies": {
    "image-size": "^2.0.2",
    "markdown-it-anchor": "^9.2.0",
    "markdown-it-task-lists": "^2.1.1",
    "pagefind": "^1.5.2"
  }
}
